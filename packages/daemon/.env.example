# Daemon runtime config
SIGNALING_SERVER=http://localhost:8095
DAEMON_ID=daemon-1
CLIENT_ID=client-1
STUN_SERVER_URLS=
TURN_SERVER_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
DAEMON_STATIC_HOST=0.0.0.0
DAEMON_STATIC_PORT=8788
DAEMON_LOG_LEVEL=info
DAEMON_LOG_FILE=/var/log/agent-browser-daemon.log
DAEMON_CLIENT_MESSAGE_TIMEOUT_SECONDS=120
# Optional directory for timeout snapshots saved as PNG files.
# DAEMON_TIMEOUT_SNAPSHOT_DIR=./log/snapshots

# Optional ICE/STUN/TURN configuration for browser P2P
# Use comma or newline separated URL lists.
# STUN_SERVER_URLS=stun:example.com:3478
# TURN_SERVER_URLS=turn:example.com:3478?transport=udp,turn:example.com:3478?transport=tcp
# TURN_USERNAME=username
# TURN_CREDENTIAL=password
# Or provide full iceServers JSON in runtime payloads.
# RTC_ICE_SERVERS_JSON=[{"urls":"stun:example.com:3478"},{"urls":["turn:example.com:3478?transport=udp","turn:example.com:3478?transport=tcp"],"username":"username","credential":"password"}]
BROWSER_HEADLESS=false

# Optional Puppeteer runtime overrides
PUPPETEER_BROWSER_CHANNEL=chrome
# DAEMON_CHROME_USER_DATA_DIR=/absolute/path/to/chrome-profile
# DAEMON_CHROME_CACHE_DIR=/absolute/path/to/chrome-cache
# PUPPETEER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
# Optional defaults for POST /api/v1/session/start
# DAEMON_SESSION_START_CHROME=C:/Program Files/Google/Chrome/Application/chrome.exe
# DAEMON_SESSION_START_CHROME_PARAMS_JSON=[{"name":"--proxy-server","value":"http://127.0.0.1:8888"}]
