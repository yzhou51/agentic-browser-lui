{
  "manifest_version": 3,
  "name": "Agentic Browser Input Bridge",
  "version": "0.1.0",
  "description": "Receives remote control commands from daemon-agent and replays them on any webpage.",
  "action": {
    "default_title": "Agentic Browser Input Bridge"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
