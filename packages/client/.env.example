# Client demo runtime defaults (Vite)
# Copy this file to .env and edit for your environment.
SIGNALING_SERVER=https://47.98.142.84:8096

# Should match the daemon's BROWSER_HEADLESS setting. Informational only: lets the
# client page know whether the daemon's Puppeteer browser runs headless, which is
# relevant for headless-only dynamic click calibration.
BROWSER_HEADLESS=true
CLIENT_STATIC_HOST=0.0.0.0
CLIENT_STATIC_PORT=80

# Optional ICE/STUN/TURN configuration for browser P2P
# Use comma or newline separated URL lists.
# STUN_SERVER_URLS=stun:example.com:3478
# TURN_SERVER_URLS=turn:example.com:3478?transport=udp,turn:example.com:3478?transport=tcp
# TURN_USERNAME=username
# TURN_CREDENTIAL=password
# Or provide the full OWT/WebRTC shape directly.
RTC_ICE_SERVERS_JSON=[{"urls":"stun:47.98.142.84:3478"},{"urls":["turn:47.98.142.84:3478?transport=udp","turn:47.98.142.84:3478?transport=tcp","turns:47.98.142.84:443?transport=tcp"],"username":"agentic-browser","credential":"IWPE_media-OWT-2026"}]
