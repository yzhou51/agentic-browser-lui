{
  "name": "agentic-browser-lui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @agentic-browser/daemon --filter @agentic-browser/client dev",
    "dev:daemon": "pnpm --filter @agentic-browser/daemon dev",
    "dev:client": "pnpm --filter @agentic-browser/client dev",
    "start:daemon": "pnpm --filter @agentic-browser/daemon start",
    "start:client": "pnpm --filter @agentic-browser/client start",
    "build:client": "pnpm --filter @agentic-browser/client build",
    "test:signal": "node tests/scripts/signal-smoke-test.mjs"
  },
  "dependencies": {
    "owt-client-javascript": "^5.0.0"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.0"
  }
}
